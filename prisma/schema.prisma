generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  author      String
  description String?  @db.Text
  price       Int
  discountPrice Int?
  image       String?  
  

  category    String   @default("Umum") 
  views       Int      @default(0)     
  
  createdAt   DateTime @default(now())
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}