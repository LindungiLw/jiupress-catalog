generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── 1. TABEL KATEGORI BARU ───
model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  icon  String // Menyimpan emoji, misal: "💻", "💼"
  
  // Relasi: 1 Kategori bisa dimiliki oleh banyak Buku
  books Book[] 
}

model Book {
  id            Int       @id @default(autoincrement())
  
  // ── Data Utama Buku ──
  title         String    // Judul
  subtitle      String?   // Sub judul (opsional)
  isbn          String?   // ISBN (opsional karena mungkin ada buku yang belum ber-ISBN)
  author        String    // Penulis
  description   String?   @db.Text // Deskripsi
  publishedDate DateTime? // Tanggal terbit (fisik) buku
  
  // ── Data Katalog & Harga ──
  price         Int
  discountPrice Int?
  image         String?   @db.LongText

  // ── Relasi Kategori ──
  categoryId    Int?
  category      Category? @relation(fields: [categoryId], references: [id])
  
  // ── SISTEM PENJADWALAN (REALTIME PUBLISH) ──
  releaseAt     DateTime  @default(now()) // Kapan buku ini boleh muncul di website
  
  // ── Statistik ──
  views         Int       @default(0)      
  createdAt     DateTime  @default(now())
}

// ─── 3. TABEL ADMIN ───
model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}