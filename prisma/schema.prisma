generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  
  // Relasi: 1 Kategori bisa dimiliki oleh banyak Buku
  books Book[] 
}

model Book {
  id            Int       @id @default(autoincrement())
  
  // ── Data Utama Buku ──
  title         String    
  subtitle      String?  
  isbn          String?   
  author        String    
  description   String?   @db.Text 
  publishedDate DateTime?
  
  // ── Data Katalog & Harga ──
  price         Int
  discountPrice Int?
  image         String?   @db.LongText

  // ── Relasi Kategori ──
  categoryId    Int?
  category      Category? @relation(fields: [categoryId], references: [id])
  
  // ── SISTEM PENJADWALAN (REALTIME PUBLISH) ──
  releaseAt     DateTime  @default(now()) 
  
  // ── Statistik ──
  views         Int       @default(0)      
  createdAt     DateTime  @default(now())
}

// ─── 3. TABEL ADMIN ───
model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}